# ===== Telegram =====
# Get from @BotFather: /newbot
TELEGRAM_BOT_TOKEN=your_bot_token_here
# Without @, e.g: my_chess_bot
TELEGRAM_BOT_USERNAME=your_bot_username
# Public HTTPS URL of your WebApp (use ngrok/cloudflared for local dev)
TELEGRAM_WEBAPP_URL=https://your-domain.com/app

# ===== Backend =====
# development or production
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
# DEBUG, INFO, WARNING, ERROR, CRITICAL
APP_LOG_LEVEL=INFO
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
APP_SECRET_KEY=your_secret_key_here_minimum_32_characters
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=1440
# For development: ["http://localhost:3000","http://localhost"]
# For production: ["https://your-domain.com"]
CORS_ORIGINS=["http://localhost:3000","http://localhost"]

# ===== Redis =====
# For Docker Compose: redis://redis:6379/0
# For local development: redis://127.0.0.1:6379/0
REDIS_URL=redis://redis:6379/0
# Game state TTL in seconds (86400 = 1 day)
REDIS_GAME_TTL_SECONDS=86400

# ===== Stockfish =====
# Docker: /usr/games/stockfish
# Windows: C:/Users/YourUser/stockfish/stockfish.exe
# Linux: /usr/bin/stockfish or install with: apt-get install stockfish
STOCKFISH_PATH=/usr/games/stockfish
# Number of worker threads for parallel game processing
STOCKFISH_WORKERS=4
# Threads per Stockfish instance (keep at 1 for multi-worker setup)
STOCKFISH_THREADS=1
# Hash table size in MB for Stockfish (32-256 depending on available RAM)
STOCKFISH_HASH_MB=32

# ===== Rate limiting =====
# Maximum requests per minute per user/IP
RATE_LIMIT_PER_MINUTE=30

# ===== Frontend (Vite build args) =====
# When using Docker Compose, Nginx proxies /api and /ws to the same host,
# so relative paths are fine. For standalone frontend, use full URLs.
VITE_API_BASE_URL=/api
VITE_WS_BASE_URL=/ws
